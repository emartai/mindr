{
  "name": "@ai-emart/mindr",
  "version": "1.0.2",
  "description": "TypeScript SDK for Mindr — persistent codebase memory for AI coding agents",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": ["ai", "memory", "agents", "mcp", "codebase", "typescript"],
  "license": "MIT",
  "author": "ai-emart",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ai-emart/mindr.git"
  },
  "homepage": "https://github.com/ai-emart/mindr",
  "bugs": {
    "url": "https://github.com/ai-emart/mindr/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-emart/mindr-core": "workspace:*",
    "@remembr/sdk": "^0.2.0"
  }
}
