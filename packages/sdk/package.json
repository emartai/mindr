{
  "name": "@emartai/mindr",
  "version": "0.2.6",
  "description": "TypeScript SDK for Mindr — persistent codebase memory for AI coding agents",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": [
    "ai",
    "memory",
    "agents",
    "mcp",
    "codebase",
    "typescript"
  ],
  "license": "MIT",
  "author": "emartai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emartai/mindr.git"
  },
  "homepage": "https://github.com/emartai/mindr",
  "bugs": {
    "url": "https://github.com/emartai/mindr/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@emartai/mindr-core": "workspace:*",
    "@remembr/sdk": "^0.2.0"
  }
}
