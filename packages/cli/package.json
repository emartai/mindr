{
  "name": "mindragent",
  "version": "0.2.4",
  "description": "Persistent codebase memory for AI coding agents",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mindr": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": ["ai", "memory", "agents", "codex", "claude-code", "mcp", "cursor", "aider", "codebase", "git", "tree-sitter"],
  "license": "MIT",
  "author": "emartai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emartai/mindr.git"
  },
  "homepage": "https://github.com/emartai/mindr",
  "bugs": {
    "url": "https://github.com/emartai/mindr/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@emartai/mindr": "workspace:*",
    "@emartai/mindr-core": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "@inquirer/prompts": "^7.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@remembr/sdk": "^0.2.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^14.0.3"
  }
}
